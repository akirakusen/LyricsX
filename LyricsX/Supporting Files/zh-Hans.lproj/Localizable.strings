/* menu item */
"Set Up YouTube Music..." = "设置 YouTube Music...";

/* YouTube Music setup alert title */
"Finish YouTube Music Setup" = "完成 YouTube Music 设置";

/* YouTube Music setup instructions */
"In Google Chrome, choose View > Developer > Allow JavaScript from Apple Events. If LyricsX was previously denied access, enable Google Chrome for LyricsX in System Settings > Privacy & Security > Automation. LyricsX only runs scripts in music.youtube.com tabs." = "在 Google Chrome 中选择“显示 > 开发者 > 允许来自 Apple 事件的 JavaScript”。如果之前拒绝过 LyricsX，请在“系统设置 > 隐私与安全性 > 自动化”中允许 LyricsX 控制 Google Chrome。LyricsX 只会在 music.youtube.com 标签页中运行脚本。";

/* YouTube Music automation alert title */
"Allow Chrome Automation" = "允许 Chrome 自动化控制";

/* YouTube Music automation recovery instructions */
"LyricsX cannot control Google Chrome because Automation access was denied. Open System Settings > Privacy & Security > Automation and enable Google Chrome for LyricsX. Then return to Chrome and keep JavaScript from Apple Events enabled." = "LyricsX 无法控制 Google Chrome，因为自动化权限已被拒绝。请打开“系统设置 > 隐私与安全性 > 自动化”，允许 LyricsX 控制 Google Chrome，然后返回 Chrome 并保持“允许来自 Apple 事件的 JavaScript”开启。";

/* YouTube Music Chrome alert title */
"Enable YouTube Music Control" = "启用 YouTube Music 控制";

/* YouTube Music Chrome setup instructions */
"In Google Chrome, choose View > Developer > Allow JavaScript from Apple Events. LyricsX only runs its integration script in music.youtube.com tabs." = "在 Google Chrome 中选择“显示 > 开发者 > 允许来自 Apple 事件的 JavaScript”。LyricsX 只会在 music.youtube.com 标签页中运行集成脚本。";

